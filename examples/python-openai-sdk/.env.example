# Required: gateway root URL (without /v1)
GATEWAY_BASE_URL=https://free-ai-gateway.sarthakagrawal927.workers.dev

# Optional: provide existing key; if empty, script requests one from /access/request-key
GATEWAY_API_KEY=

# Optional prompt/model overrides
MODEL=auto
RESPONSES_INPUT=Reply with exactly: PY_RESPONSES_OK
CHAT_PROMPT=Reply with exactly: PY_CHAT_OK
STREAM_PROMPT=Reply with exactly: PY_STREAM_OK
FORCE_PROVIDER=
