{
  "name": "@sass-maker/ai-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/mod.ts",
      "import": "./src/mod.ts"
    }
  },
  "scripts": {
    "env:sync": "node scripts/sync-dev-vars.mjs",
    "dev": "wrangler dev --remote",
    "dev:local": "npm run env:sync && wrangler dev --local",
    "deploy": "wrangler deploy",
    "deploy:cloudflare": "node scripts/deploy-cloudflare.mjs",
    "build:playground": "vite build --config playground/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:playground",
    "check": "npm run typecheck && npm test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "test:e2e:live:update": "playwright test -c playwright.live.config.ts --update-snapshots",
    "test:all": "npm run check && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "hono": "^4.11.9",
    "openai": "^6.22.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.6.0",
    "@cloudflare/workers-types": "^4.20260214.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.9",
    "wrangler": "^3.101.0"
  }
}
