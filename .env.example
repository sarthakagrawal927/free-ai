# Required gateway auth
GATEWAY_API_KEY=replace-with-gateway-api-key

# Phase 1 providers
GROQ_API_KEY=replace-with-groq-api-key
GEMINI_API_KEY=replace-with-gemini-api-key
CLI_BRIDGE_URL=http://127.0.0.1:3456
CLI_BRIDGE_PROVIDER=codex

# Cloudflare Workers AI REST fallback for local wrangler dev --local
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_WORKERS_AI_API_KEY=replace-with-cloudflare-workers-ai-token

# Optional phase 2 providers
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=

# Feature flags
PLAYGROUND_ENABLED=false
ENABLE_PHASE2=false
AUTO_ISSUE_KEYS=false
